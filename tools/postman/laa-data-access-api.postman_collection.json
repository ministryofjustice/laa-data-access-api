{
  "info": {
    "name": "LAA Data Access API",
    "_postman_id": "laa-data-access-api",
    "description": "Collection for the LAA Data Stewardship Access API.\n\nAuthentication is handled automatically via the Pre-request Script on the collection root — it calls the mock-oauth2-server token endpoint and caches the JWT in the `bearerToken` collection variable. You only need to set the environment (see the bundled environment files).\n\n## Quick start\n1. Import this collection.\n2. Import the environment file for your target (`local.postman_environment.json`, etc.).\n3. Select the environment in the top-right dropdown.\n4. Send any request — the token is fetched and cached automatically.\n\n## Refreshing the token\nThe pre-request script caches the token until its `exp` claim expires. To force a refresh, clear the `bearerToken` collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ---------------------------------------------------------------------------",
          "// Pre-request script — fetches a client_credentials token from the mock-oauth2-server",
          "// and caches it in the `bearerToken` collection variable until it expires.",
          "//",
          "// Required collection variables (set by the active environment):",
          "//   oauthTokenUrl   e.g. http://localhost:9999/entra/token",
          "//   oauthClientId   e.g. test",
          "//   oauthClientSecret  e.g. test",
          "//   oauthScope      e.g. api://laa-data-access-api/.default",
          "// ---------------------------------------------------------------------------",
          "",
          "const tokenUrl      = pm.environment.get('oauthTokenUrl')      || pm.collectionVariables.get('oauthTokenUrl');",
          "const clientId      = pm.environment.get('oauthClientId')      || 'test';",
          "const clientSecret  = pm.environment.get('oauthClientSecret')  || 'test';",
          "const scope         = pm.environment.get('oauthScope')         || 'api://laa-data-access-api/.default';",
          "",
          "if (!tokenUrl) {",
          "    console.error('oauthTokenUrl is not set. Import an environment file (e.g. local.postman_environment.json).');",
          "    return;",
          "}",
          "",
          "// Check whether the cached token is still valid (with a 60-second buffer).",
          "function tokenIsValid(token) {",
          "    if (!token) return false;",
          "    try {",
          "        const payload = JSON.parse(atob(token.split('.')[1]));",
          "        return payload.exp && (payload.exp - 60) > (Date.now() / 1000);",
          "    } catch (e) {",
          "        return false;",
          "    }",
          "}",
          "",
          "const cached = pm.collectionVariables.get('bearerToken');",
          "if (tokenIsValid(cached)) {",
          "    console.log('Using cached bearer token (still valid).');",
          "    return;",
          "}",
          "",
          "// Token has expired or is not set — fetch a new one.",
          "const body = `grant_type=client_credentials&client_id=${encodeURIComponent(clientId)}&client_secret=${encodeURIComponent(clientSecret)}&scope=${encodeURIComponent(scope)}`;",
          "",
          "pm.sendRequest({",
          "    url: tokenUrl,",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "    body: { mode: 'raw', raw: body }",
          "}, function (err, res) {",
          "    if (err) {",
          "        console.error('Token fetch failed:', err);",
          "        return;",
          "    }",
          "    if (res.code !== 200) {",
          "        console.error('Token endpoint returned HTTP', res.code, res.text());",
          "        return;",
          "    }",
          "    const json = res.json();",
          "    if (!json.access_token) {",
          "        console.error('Response did not contain access_token:', res.text());",
          "        return;",
          "    }",
          "    pm.collectionVariables.set('bearerToken', json.access_token);",
          "    console.log('Bearer token refreshed successfully.');",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "bearerToken",
      "value": "",
      "type": "string",
      "description": "Cached JWT — populated automatically by the pre-request script."
    }
  ],
  "item": [
    {
      "name": "Caseworkers",
      "item": [
        {
          "name": "GET /api/v0/caseworkers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Name", "value": "{{serviceName}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v0/caseworkers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v0", "caseworkers"]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "GET /api/v0/applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Name", "value": "{{serviceName}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v0/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v0", "applications"]
            }
          }
        },
        {
          "name": "GET /api/v0/applications/:id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Name", "value": "{{serviceName}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v0/applications/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v0", "applications", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "PATCH /api/v0/applications/:id/decision",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Service-Name", "value": "{{serviceName}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"overallDecision\": \"REFUSED\",\n  \"autoGranted\": false,\n  \"applicationVersion\": 0,\n  \"eventHistory\": { \"eventDescription\": \"Manual decision via Postman\" },\n  \"proceedings\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v0/applications/:id/decision",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v0", "applications", ":id", "decision"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Individuals",
      "item": [
        {
          "name": "GET /api/v0/individuals",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Name", "value": "{{serviceName}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v0/individuals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v0", "individuals"]
            }
          }
        }
      ]
    }
  ]
}
