{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "BaseCivilApplication.json",
  "title": "CivilApplyV2",
  "description": "Base civil application schema for data common across Civil Apply matter types",
  "type": "object",
  "required": [
    "id",
    "createdAt",
    "submittedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
        "format": "uuid",
      "description": "ID from Apply application system"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the application was created"
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the application was submitted"
    },
    "provider": {
      "$ref": "../common/2/Provider.json"
    },
    "client": {
      "$ref": "../common/2/Client.json"
    },
    "proceedings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "../common/2/Proceedings.json"
      },
      "description": "Proceedings associated with the application"
    },
    "opponents": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../common/2/Opponents.json"
      },
      "description": "Opponents associated with the application"
    }
  },
  "additionalProperties": true
}
