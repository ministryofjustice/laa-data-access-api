<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Harness infrastructure provider — always visible -->
    <logger name="uk.gov.justice.laa.dstew.access.utils.harness" level="INFO"/>

    <!-- Keep Spring/Hibernate noise down unless debugging -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <!-- Show Hibernate statistics output for query-count tests -->
    <logger name="org.hibernate.stat" level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

